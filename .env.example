# Configuração do bot WhatsApp
# Copie este arquivo para .env e preencha os valores

# Produção: mantenha "production". Em desenvolvimento, use "development".
NODE_ENV=production

# Banco SQLite desta instalação (caminho relativo à pasta prisma)
DATABASE_URL="file:./dev.db"

# Opcional: use 'true' para habilitar logs de debug do whatsapp-web.js
WHATSAPP_DEBUG=false

# Produção: true. Para ler o QR code inicialmente, o QR também aparece no terminal.
WHATSAPP_HEADLESS=true

# Caminho do Chrome no servidor Windows
CHROME_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# Opcional: fixa uma versão do WhatsApp Web já salva em .wwebjs_cache
WHATSAPP_WEB_VERSION=

# Opcional: nome customizado da sessão (default: 'tireflow-session')
WHATSAPP_SESSION_NAME=tireflow-session

# NOME DA FILIAL — ALTERE SOMENTE ESTA LINHA EM CADA INSTALAÇÃO
# Congo: BRANCH_NAME="ATC PNEUS CONGO"
# Monteiro: BRANCH_NAME="ATC PNEUS MONTEIRO"
BRANCH_NAME="ATC PNEUS CONGO"

# Opcional: pasta local para salvar a sessão fora do OneDrive
# Exemplo Windows: C:\Users\Emano\AppData\Local\TireFlow\wwebjs_auth
WHATSAPP_AUTH_DATA_PATH=

# Obrigatório no MVP para validar o grupo oficial
# Exemplo: 120363xxxxxxxx@g.us
# Para descobrir, envie "grupo id" dentro do grupo do WhatsApp.
WHATSAPP_OFFICIAL_GROUP_ID=

# Obrigatório para notificações privadas de movimentações
# Use DDI + DDD + número. Exemplo: 5583999999999
BOSS_PRIVATE_NUMBER=

# Obrigatório para o relatório diário automático
# Pode ser o mesmo valor de BOSS_PRIVATE_NUMBER.
OWNER_PHONE=

# Horário local para enviar o relatório diário automático
# Formato: HH:mm. Exemplo: 18:00
DAILY_REPORT_TIME=

# Opcional: true permite usar os comandos também em conversa privada para testes.
# Pode ser true ou false inclusive em produção; false mantém somente o grupo oficial.
ALLOW_PRIVATE_TEST_MODE=false

# Quantidade máxima de backups mantidos por npm run backup
BACKUP_RETENTION=14

# Logs da aplicação: 10 MB por arquivo, mantendo 30 dias
LOG_MAX_BYTES=10485760
LOG_RETENTION_DAYS=30

# No terminal use true. O instalador NSSM sobrescreve para false no serviço,
# evitando duplicar os logs rotativos da aplicação no stdout/stderr do NSSM.
LOG_TO_CONSOLE=true

# Intervalo do health check periódico gravado nos logs
HEALTH_LOG_INTERVAL_MINUTES=15
