generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MovementType {
  SALE
  ENTRY
  ADJUSTMENT
  PRICE_CHANGE
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  role      String   @default("USER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements      Movement[]
  userSessions   UserSession[]
  searchSessions SearchSession[]

  @@map("users")
}

model Product {
  id          String   @id @default(cuid())
  reference   String
  description String
  stock       Int      @default(0)
  minStock    Int      @default(0)
  cashPrice   Decimal
  creditPrice Decimal
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements Movement[]

  @@index([reference])
  @@index([isActive])
  @@map("products")
}

model Movement {
  id            String       @id @default(cuid())
  code          String       @unique
  type          MovementType
  productId     String
  userId        String
  quantity      Int?
  previousStock Int?
  newStock      Int?
  unitPrice     Decimal?
  totalValue    Decimal?
  paymentMethod String?
  invoiceName   String?
  observation   String?
  supplier      String?
  reason        String?
  createdAt     DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("movements")
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  chatId      String
  type        String
  step        String
  payloadJson String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, chatId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model SearchSession {
  id          String   @id @default(cuid())
  userId      String
  chatId      String
  resultsJson String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, chatId])
  @@index([expiresAt])
  @@map("search_sessions")
}
